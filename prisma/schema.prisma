generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id              Int       @id @default(autoincrement())
  name            String
  slug            String    @unique
  subscriptionEnd DateTime?
  createdAt       DateTime  @default(now())
  businessType    String    @default("RESTAURANT") // RESTAURANT, GROCERY, PHARMACY, ETC.
  
  users           User[]
  configs         Config[]
  categories      Category[]
  products        Product[]
  modifierOptions ModifierOption[]
  orders          Order[]
  businessHours   BusinessHour[]
  coupons         Coupon[]
  receipts        Receipt[]
  drivers         Driver[]
  banners         Banner[]
  managers        User[]    @relation("ManagedRestaurants")
}

model User {
  id           Int         @id @default(autoincrement())
  username     String      @unique
  password     String
  rawPassword  String?
  role         String      @default("ADMIN") // SUPERADMIN o ADMIN
  restaurantId Int?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  managedRestaurants Restaurant[] @relation("ManagedRestaurants")
  driver       Driver?
}

model Config {
  id             Int        @id @default(autoincrement())
  whatsappNumber String
  openTime       String     // HH:MM format
  closeTime      String     // HH:MM format
  isOpenOverride Boolean    @default(true) 
  isSuspended    Boolean    @default(false)
  logoUrl        String?
  subtitle       String?    @default("Delivery & Takeaway")
  themeColor     String?    @default("#e11d48")
  buttonColor    String?    @default("#ffffff")
  bgColor        String?    @default("#ffffff")
  cardColor      String?    @default("#ffffff")
  textColor      String?    @default("#1a1a1a")
  fontFamily     String?    @default("Inter")
  cardLayout     String?    @default("grid")
  bankAlias      String?
  instagramUrl   String?
  whatsappUrl    String?
  mapsUrl        String?
  shippingFee    Float      @default(0)
  restaurantId   Int
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model Category {
  id           Int        @id @default(autoincrement())
  name         String     
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  products     Product[]
  discounts    CategoryDiscount[]
}

model CategoryDiscount {
  id           Int        @id @default(autoincrement())
  quantity     Int
  price        Float
  categoryId   Int
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  @@unique([categoryId, quantity])
}

model Product {
  id           Int              @id @default(autoincrement())
  name         String
  description  String?
  price        Float
  imageUrl     String?
  categoryId   Int?
  category     Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  isPromo      Boolean          @default(false)
  isActive     Boolean          @default(true)
  allowBulkQuantities Boolean   @default(false)
  modifiers    ModifierOption[]
  restaurantId Int
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model ModifierOption {
  id           Int        @id @default(autoincrement())
  name         String
  description  String?
  price        Float      @default(0)
  type         String     @default("FREE") // "FREE" o "PAID"
  products     Product[]
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model Order {
  id             Int         @id @default(autoincrement())
  customerName   String
  customerPhone  String?
  deliveryMethod String      
  address        String?
  status         String      @default("AWAITING_CONFIRMATION") 
  total          Float
  createdAt      DateTime    @default(now())
  items          OrderItem[]
  customerNotes  String?
  paymentMethod  String?
  paymentDetails String?
  couponCode     String?
  discountApplied Float      @default(0)
  tipAmount      Float       @default(0)
  cancelReason   String?
  restaurantId   Int
  restaurant     Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  driverId       Int?
  driver         Driver?     @relation(fields: [driverId], references: [id], onDelete: SetNull)
}

model OrderItem {
  id              Int     @id @default(autoincrement())
  orderId         Int
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       Int
  productName     String  
  quantity        Int
  priceAtPurchase Float   
  notes           String? 
}

model SystemConfig {
  id             Int     @id @default(autoincrement())
  supportContact String? @default("")
}

model BusinessHour {
  id           Int        @id @default(autoincrement())
  dayOfWeek    Int        // 0 = Domingo, 1 = Lunes, etc.
  isOpen       Boolean    @default(true)
  shift1Open   String?    // e.g. "12:00"
  shift1Close  String?    // e.g. "15:00"
  shift2Open   String?    // e.g. "20:00"
  shift2Close  String?    // e.g. "00:00"
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, dayOfWeek])
}

model Coupon {
  id           Int        @id @default(autoincrement())
  code         String     // e.g. "PLANB10"
  discountType String     // "PERCENTAGE" o "FIXED"
  discountValue Float
  minPurchase  Float      @default(0)
  isActive     Boolean    @default(true)
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, code])
}

model Receipt {
  id           Int        @id @default(autoincrement())
  receiptNumber String    @unique // e.g. "REC-0001"
  amount       Float
  issuedAt     DateTime   @default(now())
  periodStart  DateTime
  periodEnd    DateTime
  description  String?
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model Driver {
  id           Int        @id @default(autoincrement())
  name         String
  phone        String
  isActive     Boolean    @default(true)
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  userId       Int?       @unique
  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]
}

model Banner {
  id           Int        @id @default(autoincrement())
  imageUrl     String
  link         String?
  isActive     Boolean    @default(true)
  orderIndex   Int        @default(0)
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}
